# Ollama 서버
OLLAMA_BASE_URL=http://localhost:11434

# 임베딩 (한국어 RAG: bge-m3 추천)
EMBEDDING_MODEL=bge-m3

# 챗 LLM (qwen 계열)
#   qwen2.5:7b       ~4.7GB  기본 권장 (한국어 품질/리소스 균형)
#   qwen2.5:14b      ~9GB    16GB+ RAM, 더 정확
#   qwen2.5:3b       ~2GB    저사양
CHAT_MODEL=qwen2.5:7b

# RAG 파라미터
CHUNK_SIZE=700
CHUNK_OVERLAP=100
TOP_K=4

# 챗 옵션
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=1024
CHAT_STREAM=true

# 임베딩 동시 요청 수
EMBED_CONCURRENCY=4
